{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.2",
      "config": {
        "includeFiles": [
          "public/**",
          "resources/**",
          "routes/**",
          "config/**",
          "app/**",
          "database/**",
          "bootstrap/**",
          "storage/**",
          "vendor/**"
        ]
      }
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "LOG_STACK": "stderr",
    "LOG_DEPRECATIONS_CHANNEL": "null",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "sync",
    "VIEW_COMPILED_PATH": "/tmp/views"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
